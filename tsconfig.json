{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "rootDir": "./features",
    "outDir": "./dist",
    "ignoreDeprecations": "6.0"
  },
  "include": ["features/**/*.ts"],
  "exclude": ["node_modules"]
}
